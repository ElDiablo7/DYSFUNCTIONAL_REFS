# Required
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_BUSINESS_NAME="The Dysfunctional Referees"

# Email (optional - forms log to console in dev without these)
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
RESEND_API_KEY=

# Database (optional - site uses local content without this)
DATABASE_URL=

# Admin (optional - admin area disabled without these)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Media Storage (optional - uploads disabled without these)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Analytics (optional - no tracking without these)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
