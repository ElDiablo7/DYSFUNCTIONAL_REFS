generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  password_hash String
  role          String   @default("REFEREE") // "REFEREE" or "ADMIN"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  media         Media[]
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   // "PHOTO" or "VIDEO"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Enquiry {
  id        String   @id @default(cuid())
  type      String   // "BOOKING" or "JOIN"
  name      String
  email     String
  telephone String?
  details   String   // JSON string of all specific fields
  status    String   @default("NEW") // "NEW" or "REVIEWED"
  createdAt DateTime @default(now())
}
